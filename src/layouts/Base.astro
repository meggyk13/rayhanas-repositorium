---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "SCA research, class handouts, and tools from Rayhana bint Estafanos al-Abbas" } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/ans/', label: 'A&S', hint: 'Projects' },
  { href: '/handouts/', label: 'Classes', hint: 'Handouts' },
  { href: '/articles/', label: 'Articles' },
  { href: '/tools/', label: 'Tools', hint: 'Calculators' },
];

function isCurrent(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Rayhana's Repositorium</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="Rayhana's Repositorium" />
    <meta property="og:image" content={new URL('/images/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="site-title" href="/">Rayhana&rsquo;s Repositorium</a>
        <nav class="site-nav" aria-label="Main">
          {nav.map((item) => (
            <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
        <button class="menu-btn" aria-expanded="false" aria-controls="site-menu" data-menu-open>
          Menu
          <span class="bars" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </header>

    <div class="menu-overlay" id="site-menu" role="dialog" aria-modal="true" aria-label="Main menu">
      <div class="menu-top">
        <span class="site-title">Rayhana&rsquo;s Repositorium</span>
        <button class="menu-close" data-menu-close>Close ✕</button>
      </div>
      <ul class="menu-list">
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
              <span class="diamond"></span>{item.label}
              {item.hint && <span class="hint">{item.hint}</span>}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p>
          Rayhana bint Estafanos al-Abbas &middot; Kingdom of Caid.
          Not an
          official publication of the SCA, Inc.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var overlay = document.getElementById('site-menu');
        var openBtn = document.querySelector('[data-menu-open]');
        var closeBtn = document.querySelector('[data-menu-close]');
        function open() {
          overlay.classList.add('open');
          document.body.classList.add('menu-locked');
          openBtn.setAttribute('aria-expanded', 'true');
          closeBtn.focus();
        }
        function close() {
          overlay.classList.remove('open');
          document.body.classList.remove('menu-locked');
          openBtn.setAttribute('aria-expanded', 'false');
          openBtn.focus();
        }
        openBtn.addEventListener('click', open);
        closeBtn.addEventListener('click', close);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('open')) close();
        });
      })();
    </script>
  </body>
</html>
