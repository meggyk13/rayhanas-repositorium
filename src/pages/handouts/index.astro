---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('handouts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Class Handouts">
  <div class="wrap">
    <header class="entry-header">
      <h1>Class Handouts</h1>
      <p class="prose">
        Handouts from classes I teach. If you took a class and want the
        take-home version, it lives here.
      </p>
    </header>
    <ul class="card-grid">
      {entries.map((e) => (
        <li class="card">
          <p class="meta">{e.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>
          <h3><a href={`/handouts/${e.id}/`}>{e.data.title}</a></h3>
          <p>{e.data.summary}</p>
        </li>
      ))}
    </ul>
  </div>
</Base>
