---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('handouts');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title} description={entry.data.summary}>
  <div class="wrap">
    <header class="entry-header prose">
      <p class="meta">
        {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        {entry.data.tags.length > 0 && ` · ${entry.data.tags.join(' · ')}`}
      </p>
      <h1>{entry.data.title}</h1>
      {entry.data.pdf && (
        <p><a href={entry.data.pdf}>Download the PDF version</a></p>
      )}
    </header>
    <article class="entry-body prose">
      <Content />
    </article>
  </div>
</Base>
